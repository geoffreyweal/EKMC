k_{12} & =\frac{2\pi}{\hbar}\left|V_{12}\right|^{2}\sqrt{\frac{1}{4\pi\lambda_{c}k_{B}T}}\exp\left(-\frac{\left(\Delta E+\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
First, we will simplify some of the constant at the beginning of this equation
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
k_{12} & =\frac{2\pi}{\hbar}\left|V_{12}\right|^{2}\sqrt{\frac{1}{4\pi\lambda_{c}k_{B}T}}\exp\left(-\frac{\left(\Delta E+\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right)\\
 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{4\pi^{2}}{4\pi\lambda_{c}k_{B}T}}\exp\left(-\frac{\left(\Delta E+\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right)\\
 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\exp\left(-\frac{\left(\Delta E+\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Next, we will expand the quadratic in the exponential, to give: 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
k_{12} & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\exp\left(-\frac{\left(\Delta E+\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right)\\
 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\exp\left(-\frac{\left(\Delta E\right)^{2}+2\left(\Delta E\right)\left(\lambda_{c}\right)+\left(\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right)\\
 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\exp\left(-\left[\frac{\left(\Delta E\right)^{2}}{4\lambda_{c}k_{B}T}+\frac{2\left(\Delta E\right)\left(\lambda_{c}\right)}{4\lambda_{c}k_{B}T}+\frac{\left(\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right]\right)\\
 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\exp\left(-\left[\frac{\left(\Delta E\right)^{2}}{4\lambda_{c}k_{B}T}+\frac{\left(\Delta E\right)\left(\lambda_{c}\right)}{2\lambda_{c}k_{B}T}+\frac{\left(\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right]\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
If we now add random disorder to 
\begin_inset Formula $\Delta E$
\end_inset

 and 
\begin_inset Formula $V_{12}$
\end_inset

, such that
\end_layout

\begin_layout Itemize
\begin_inset Formula $\Delta E_{12}=\left(E_{1}-E_{2}\right)\rightarrow\left(\mathrm{normrad}\left(E_{1},d_{E,1}\right)-\mathrm{normrad}\left(E_{2},d_{E,2}\right)\right)=\Gamma_{12}$
\end_inset

, 
\end_layout

\begin_layout Itemize
\begin_inset Formula $V_{12}\rightarrow\mathrm{normrad}\left(V_{12},d_{V}\right)=V_{12}\mathrm{normrad}\left(1,d_{V}\right)=V_{12}\Lambda_{12}$
\end_inset

 
\end_layout

\begin_layout Standard
This gives
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
k_{12} & =\frac{\left|V_{12}\Lambda_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\exp\left(-\left[\frac{\left(\Gamma_{12}\right)^{2}}{4\lambda_{c}k_{B}T}+\frac{\left(\Gamma_{12}\right)\left(\lambda_{c}\right)}{2\lambda_{c}k_{B}T}+\frac{\left(\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right]\right)\\
 & =\Lambda_{12}^{2}\left[\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\right]\exp\left(-\left[\Gamma_{12}^{2}\left[\frac{1}{4\lambda_{c}k_{B}T}\right]+\Gamma_{12}\left[\frac{\left(\lambda_{c}\right)}{2\lambda_{c}k_{B}T}\right]+\left[\frac{\left(\lambda_{c}\right)^{2}}{4\lambda_{c}k_{B}T}\right]\right]\right)\\
 & =\Lambda_{12}^{2}\left[\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\right]\exp\left(-\left[\Gamma_{12}^{2}\left[\frac{1}{4\lambda_{c}k_{B}T}\right]+\Gamma_{12}\left[\frac{1}{2k_{B}T}\right]+\left[\frac{\lambda_{c}}{4k_{B}T}\right]\right]\right)\\
 & =\Lambda_{12}^{2}M\left(V_{12},\lambda_{c},T\right)\exp\left(-\left[\Gamma_{12}^{2}X\left(\lambda_{c},T\right)+\Gamma_{12}Y\left(T\right)+Z\left(\lambda_{c},T\right)\right]\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
where
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
M\left(V_{12},\lambda_{c},T\right) & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\\
X\left(\lambda_{c},T\right) & =\frac{1}{4\lambda_{c}k_{B}T}\\
Y\left(T\right) & =\frac{1}{2k_{B}T}\\
Z\left(\lambda_{c},T\right) & =\frac{\lambda_{c}}{4k_{B}T}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
and
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\Gamma_{12} & =\left(\mathrm{normrad}\left(E_{1},d_{E,1}\right)-\mathrm{normrad}\left(E_{2},d_{E,2}\right)\right)\\
\Lambda_{12} & =\mathrm{normrad}\left(1,d_{V}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Section
