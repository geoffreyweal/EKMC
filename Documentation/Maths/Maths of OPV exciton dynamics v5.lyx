 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\underset{u}{\sum}P\left(u\right)\underset{v}{\sum}\left|S\left(u,v\right)\right|^{2}\exp\left(-\frac{\left(\Delta E\right)^{2}+2\left(\Delta E\right)\left(\lambda_{c}+\left(u-v\right)\hbar\omega^{A}\right)+\left(\lambda_{c}+\left(u-v\right)\hbar\omega^{A}\right)^{2}}{4\lambda_{c}k_{B}T}\right)\\
 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\underset{u}{\sum}\underset{v}{\sum}P\left(u\right)\left|S\left(u,v\right)\right|^{2}\exp\left(-\left[\frac{\left(\Delta E\right)^{2}}{4\lambda_{c}k_{B}T}+\frac{2\left(\Delta E\right)\left(\lambda_{c}+\left(u-v\right)\hbar\omega^{A}\right)}{4\lambda_{c}k_{B}T}+\frac{\left(\lambda_{c}+\left(u-v\right)\hbar\omega^{A}\right)^{2}}{4\lambda_{c}k_{B}T}\right]\right)\\
 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\underset{u}{\sum}\underset{v}{\sum}P\left(u\right)\left|S\left(u,v\right)\right|^{2}\exp\left(-\left[\frac{\left(\Delta E\right)^{2}}{4\lambda_{c}k_{B}T}+\frac{\left(\Delta E\right)\left(\lambda_{c}+\left(u-v\right)W\right)}{2\lambda_{c}k_{B}T}+\frac{\left(\lambda_{c}+\left(u-v\right)W\right)^{2}}{4\lambda_{c}k_{B}T}\right]\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Where 
\begin_inset Formula $W=\hbar\omega^{A}$
