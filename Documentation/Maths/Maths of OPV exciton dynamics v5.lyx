 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{4\pi^{2}}{4\pi\lambda_{c}k_{B}T}}\underset{u}{\sum}P\left(u\right)\underset{v}{\sum}\left|S\left(u,v\right)\right|^{2}\exp\left(-\frac{\left(\Delta E+\lambda_{c}+\left(u-v\right)\hbar\omega^{A}\right)^{2}}{4\lambda_{c}k_{B}T}\right)\\
 & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\underset{u}{\sum}P\left(u\right)\underset{v}{\sum}\left|S\left(u,v\right)\right|^{2}\exp\left(-\frac{\left(\Delta E+\lambda_{c}+\left(u-v\right)\hbar\omega^{A}\right)^{2}}{4\lambda_{c}k_{B}T}\right)
