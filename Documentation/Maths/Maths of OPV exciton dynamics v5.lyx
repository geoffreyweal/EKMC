k_{12} & =\frac{\left|V_{12}\Lambda_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\underset{u}{\sum}\underset{v}{\sum}P\left(u\right)\left|S\left(u,v\right)\right|^{2}\exp\left(-\left[\frac{\left(\Gamma_{12}\right)^{2}}{4\lambda_{c}k_{B}T}+\frac{\left(\Gamma_{12}\right)\left(\lambda_{c}+\left(u-v\right)W\right)}{2\lambda_{c}k_{B}T}+\frac{\left(\lambda_{c}+\left(u-v\right)W\right)^{2}}{4\lambda_{c}k_{B}T}\right]\right)\\
 & =\Lambda_{12}^{2}\left[\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\right]\underset{u}{\sum}\underset{v}{\sum}\left[P\left(u\right)\left|S\left(u,v\right)\right|^{2}\right]\exp\left(-\left[\Gamma_{12}^{2}\left[\frac{1}{4\lambda_{c}k_{B}T}\right]+\Gamma_{12}\left[\frac{\left(\lambda_{c}+\left(u-v\right)W\right)}{2\lambda_{c}k_{B}T}\right]+\left[\frac{\left(\lambda_{c}+\left(u-v\right)W\right)^{2}}{4\lambda_{c}k_{B}T}\right]\right]\right)\\
 & =\Lambda_{12}^{2}M\left(V_{12},\lambda_{c},T\right)\underset{u}{\sum}\underset{v}{\sum}N\left(u,v\right)\exp\left(-\left[\Gamma_{12}^{2}X\left(\lambda_{c},T\right)+\Gamma_{12}Y\left(W,u,v,\lambda_{c},T\right)+Z\left(W,u,v,\lambda_{c},T\right)\right]\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
where
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
M\left(V_{12},\lambda_{c},T\right) & =\frac{\left|V_{12}\right|^{2}}{\hbar}\sqrt{\frac{\pi}{\lambda_{c}k_{B}T}}\\
N\left(u,v\right) & =P\left(u\right)\left|S\left(u,v\right)\right|^{2}\\
X\left(\lambda_{c},T\right) & =\frac{1}{4\lambda_{c}k_{B}T}\\
Y\left(W,u,v,\lambda_{c},T\right) & =\frac{\left(\lambda_{c}+\left(u-v\right)W\right)}{2\lambda_{c}k_{B}T}\\
Z\left(W,u,v,\lambda_{c},T\right) & =\frac{\left(\lambda_{c}+\left(u-v\right)W\right)^{2}}{4\lambda_{c}k_{B}T}
\end{align*}

\end_inset


\end_layout

