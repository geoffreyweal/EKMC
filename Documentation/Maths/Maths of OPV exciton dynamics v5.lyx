\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\rho_{FCWT}^{MLJ}\left(\Delta E_{12}\right) & =\sqrt{\frac{1}{4\pi\lambda_{c}k_{B}T}}\underset{u}{\sum}P\left(u\right)\underset{v}{\sum}\left|S\left(u,v\right)\right|^{2}\exp\left(-\frac{\left(\Delta E+\lambda_{c}-\left(u-v\right)\hbar\omega^{A}\right)^{2}}{4\lambda_{c}k_{B}T}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
and
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
S\left(u,v\right)= & e^{-\frac{G}{2}}\stackrel[i=0]{u}{\sum}\stackrel[j=0]{v}{\sum}\frac{\left(-1\right)^{j}\left(\sqrt{G}\right)^{i+j}}{i!j!}\sqrt{\frac{u!v!}{\left(u-i\right)!\left(v-j\right)!}}\delta_{u-i,v-j}
\end{align*}

\end_inset


