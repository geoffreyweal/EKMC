\begin_layout Subsection
Focus on S
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
S\left(u,v\right)= & e^{-\frac{G}{2}}\stackrel[i=0]{u}{\sum}\stackrel[j=0]{v}{\sum}\frac{\left(-1\right)^{j}\left(\sqrt{G}\right)^{i+j}}{i!j!}\sqrt{\frac{u!v!}{\left(u-i\right)!\left(v-j\right)!}}\delta_{u-i,v-j}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
S\left(u,v\right)= & e^{-\frac{G}{2}}\stackrel[i=0]{u}{\sum}\stackrel[j=0]{v}{\sum}\frac{\left(-1\right)^{j}\left(\sqrt{G}\right)^{i+j}}{i!j!}\sqrt{\frac{u!v!}{\left(u-i\right)!\left(v-j\right)!}}\delta_{u-i,v-j}\\
= & e^{-\frac{G}{2}}\stackrel[i=0]{u}{\sum}\stackrel[j=0]{v}{\sum}\left(-1\right)^{j}\left(\sqrt{G}\right)^{i+j}\frac{1}{i!j!}\sqrt{\frac{u!v!}{\left(u-i\right)!\left(v-j\right)!}}\delta_{u-i,v-j}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
where
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\frac{1}{i!j!}\sqrt{\frac{u!v!}{\left(u-i\right)!\left(v-j\right)!}}\delta_{u-i,v-j}= & \sqrt{\frac{1}{i!j!}}\sqrt{\frac{1}{i!j!}}\sqrt{\frac{u!v!}{\left(u-i\right)!\left(v-j\right)!}}\delta_{u-i,v-j}\\
= & \sqrt{\frac{1}{i!j!}}\sqrt{\frac{u!v!}{i!j!\left(u-i\right)!\left(v-j\right)!}}\delta_{u-i,v-j}\\
= & \sqrt{\frac{1}{i!j!}}\sqrt{\frac{u!}{i!\left(u-i\right)!}}\sqrt{\frac{v!}{j!\left(v-j\right)!}}\delta_{u-i,v-j}\\
= & \sqrt{\frac{1}{i!j!}}\sqrt{\frac{u!}{i!\left(u-i\right)!}}\sqrt{\frac{v!}{j!\left(v-j\right)!}}\delta_{u-i,v-j}\\
= & \sqrt{\frac{1}{i!j!}\times\left(\begin{array}{c}
u\\
i
\end{array}\right)\left(\begin{array}{c}
v\\
j
\end{array}\right)}\delta_{u-i,v-j}
\end{align*}

\end_inset


